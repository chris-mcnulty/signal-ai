modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "seo-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-client-drift"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "site-network-error-tests"

[[workflows.workflow]]
name = "seo-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-client-drift"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-spec run codegen && git diff --exit-code"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "site-network-error-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/site test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 21238
externalPort = 3000

[[ports]]
localPort = 23183
externalPort = 80

[userenv]

[userenv.shared]
SITE_URL = "https://www.bluetrail.ai"
SITE_NAME = "BlueTrail Intelligence Report"
SITE_PUBLISHER = "BlueTrail Intelligence Ltd."
SITE_TAGLINE = "Blazing the AI trail ahead of the frontier"
SITE_DESCRIPTION = "The BlueTrail Intelligence Report covers commercial AI: enterprise deployments, industry analysis, use cases, and the forces shaping what comes next."
